{$DOMAIN:localhost} {
    # Reverse proxy to FastAPI app
    reverse_proxy app:8000

    # Security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }

    # Compress responses
    encode gzip zstd

    # Logs
    log {
        output stdout
        format console
    }
}
