# ClassGen Production Environment
# Copy to .env.prod and fill in all values before deploying.

# --- Required ---

# Domain (must match DNS A record pointing to this server)
DOMAIN=classgen.ng

# OpenRouter LLM
OPENROUTER_API_KEY=sk-or-v1-...

# Supabase Cloud (https://supabase.com/dashboard)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJ...your-anon-key

# Twilio WhatsApp (https://console.twilio.com)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=whatsapp:+14155238886

# Web Push (generate with: uv run python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); ...")
VAPID_PRIVATE_KEY=...
VAPID_PUBLIC_KEY=...
VAPID_CONTACT=mailto:admin@classgen.ng

# --- Optional ---

# Paystack billing
PAYSTACK_SECRET_KEY=

# Redis (set automatically by docker-compose, override for external Redis)
# REDIS_URL=redis://redis:6379/0
