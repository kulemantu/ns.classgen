# ClassGen Production Environment
# Copy to .env.prod and fill in all values before deploying.

# --- Required ---

# OpenRouter LLM
OPENROUTER_API_KEY=sk-or-v1-...

# Domain (nginx-proxy)
VIRTUAL_HOST=class.dater.world
LETSENCRYPT_HOST=class.dater.world
LETSENCRYPT_EMAIL=admin@dater.world

# Postgres (used by db + rest services)
# Generate with: openssl rand -base64 24 | tr -d '/+='
POSTGRES_PASSWORD=CHANGE_ME

# PostgREST JWT secret (min 32 chars)
# Generate with: openssl rand -base64 48 | tr -d '/+='
PGRST_JWT_SECRET=CHANGE_ME_MIN_32_CHARACTERS

# PostgREST anon key (JWT signed with PGRST_JWT_SECRET for role=classgen_api)
# Generate: python3 -c "import json,base64,hmac,hashlib; h=base64.urlsafe_b64encode(json.dumps({'alg':'HS256','typ':'JWT'}).encode()).rstrip(b'=').decode(); p=base64.urlsafe_b64encode(json.dumps({'role':'classgen_api'}).encode()).rstrip(b'=').decode(); s=base64.urlsafe_b64encode(hmac.new(b'YOUR_JWT_SECRET',f'{h}.{p}'.encode(),hashlib.sha256).digest()).rstrip(b'=').decode(); print(f'{h}.{p}.{s}')"
SUPABASE_ANON_KEY=CHANGE_ME

# --- Optional ---

# Twilio WhatsApp (https://console.twilio.com)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Web Push (generate with: uv run python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); ...")
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CONTACT=mailto:admin@dater.world

# Paystack billing
PAYSTACK_SECRET_KEY=

# Redis (set automatically by docker-compose, override for external Redis)
# REDIS_URL=redis://redis:6379/0
