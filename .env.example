# API Keys
OPENROUTER_API_KEY=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""

# Supabase (cloud or docker compose PostgREST)
# For docker compose: SUPABASE_URL=http://rest:3000
SUPABASE_URL=""
SUPABASE_KEY=""

# Docker compose PostgREST JWT — must match PGRST_JWT_SECRET + PGRST_DB_ANON_ROLE
# Generate with: python3 -c "import json,base64,hmac,hashlib; h=base64.urlsafe_b64encode(json.dumps({'alg':'HS256','typ':'JWT'}).encode()).rstrip(b'=').decode(); p=base64.urlsafe_b64encode(json.dumps({'role':'classgen_api'}).encode()).rstrip(b'=').decode(); s=base64.urlsafe_b64encode(hmac.new(b'super-secret-jwt-token-with-at-least-32-characters',f'{h}.{p}'.encode(),hashlib.sha256).digest()).rstrip(b'=').decode(); print(f'{h}.{p}.{s}')"
SUPABASE_ANON_KEY="your-anon-key-here"

# Redis (set by docker compose, or point to external instance)
REDIS_URL=""

# Web Push Notifications (VAPID keys)
# Generate with: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print('PRIVATE:', v.private_pem()); print('PUBLIC:', v.public_key)"
VAPID_PRIVATE_KEY=""
VAPID_PUBLIC_KEY=""
VAPID_CONTACT="mailto:help@dater.world"

# Optional: Paystack billing
PAYSTACK_SECRET_KEY=""

# Optional Twilio Testing
TWILIO_PHONE_NUMBER=""
